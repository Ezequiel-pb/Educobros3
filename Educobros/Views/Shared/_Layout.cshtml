<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduCobros</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Educobros.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-wrapper">
        <header class="app-header">
            <nav class="navbar navbar-expand-lg custom-navbar">
                <div class="container-fluid px-4">
                    <a class="navbar-brand brand-custom" asp-controller="Home" asp-action="Index">
                        <span class="brand-logo">E</span>
                        <span>EduCobros</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 nav-custom">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                            </li>

                            @if (User.IsInRole("Admin") || User.IsInRole("Secretaria"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Estudiantes" asp-action="Index">Estudiantes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Pagos" asp-action="Create">Registrar pago</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Pagos" asp-action="Index">Reportes</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                            </li>
                        </ul>

                        <div class="nav-user-area">
                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="main-content container-fluid px-4 py-4">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <div class="container-fluid px-4 d-flex justify-content-between flex-wrap gap-2">
                <span>&copy; 2026 - EduCobros</span>
                <a asp-controller="Home" asp-action="Privacy">Política de privacidad</a>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>