@model EduCobros.Models.Estudiante

@{
    ViewData["Title"] = "Nuevo Estudiante";
}

<section class="page-shell">
    <div class="page-header">
        <div>
            <span class="page-badge">Gestión académica</span>
            <h1 class="page-title">Registrar nuevo estudiante</h1>
            <p class="page-subtitle">Completa la información básica del estudiante para agregarlo al sistema.</p>
        </div>
        <div class="page-actions">
            <a asp-action="Index" class="btn btn-light-custom">Volver</a>
        </div>
    </div>

    <div class="form-panel">
        <form asp-action="Create" method="post" class="custom-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

            <div class="form-grid">
                <div class="form-group-custom full-width">
                    <label asp-for="Nombre" class="form-label-custom"></label>
                    <input asp-for="Nombre" class="form-control-custom" placeholder="Ej: Juan Pérez" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Grado" class="form-label-custom"></label>
                    <select asp-for="Grado" class="form-select-custom">
                        <option value="">-- Seleccionar --</option>
                        <option>1ro Primaria</option>
                        <option>2do Primaria</option>
                        <option>3ro Primaria</option>
                        <option>4to Primaria</option>
                        <option>5to Primaria</option>
                        <option>6to Primaria</option>
                        <option>1ro Sec.</option>
                        <option>2do Sec.</option>
                        <option>3ro Sec.</option>
                    </select>
                    <span asp-validation-for="Grado" class="text-danger small"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Mensualidad" class="form-label-custom"></label>
                    <input asp-for="Mensualidad" class="form-control-custom" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="Mensualidad" class="text-danger small"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="MesesDebidos" class="form-label-custom"></label>
                    <input asp-for="MesesDebidos" class="form-control-custom" type="number" min="0" max="12" value="0" />
                    <span asp-validation-for="MesesDebidos" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn btn-primary-custom">Guardar estudiante</button>
                <a asp-action="Index" class="btn btn-outline-custom">Cancelar</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}